# ─── Supabase ───────────────────────────────────────────────────────────────
# Required for database functionality. Get from supabase.com project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Providers ───────────────────────────────────────────────────────────
# Optional. Anthropic takes precedence over OpenAI. If neither is set,
# AI-augmented intent detection and valuation narratives are disabled.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── CRM Adapters ───────────────────────────────────────────────────────────
# Optional. If absent, the null adapter is used (no external CRM writes).
# All CRM calls are logged to crm_sync_log regardless.

# Follow Up Boss
FUB_API_KEY=
FUB_BASE_URL=https://api.followupboss.com/v1

# kvCORE
KVCORE_API_KEY=
KVCORE_BASE_URL=

# ─── Notifications ──────────────────────────────────────────────────────────
# Optional. Used for agent notification emails and SMS.
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# ─── AVM Providers ──────────────────────────────────────────────────────────
# Optional. If absent, mock provider is used (no real valuations).
ATTOM_API_KEY=
HOUSECANARY_API_KEY=
HOUSECANARY_API_SECRET=

# ─── App Configuration ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AGENT_NAME=Mike Eatmon
NEXT_PUBLIC_BROKERAGE_NAME=Our Town Properties
NEXT_PUBLIC_AGENT_PHONE=+12522454337
NEXT_PUBLIC_MARKET_AREA=Wilson, NC
NEXT_PUBLIC_AGENT_LICENSE=NC-YOUR-LICENSE-NUMBER

# ─── Admin ──────────────────────────────────────────────────────────────────
# Basic auth secret for /admin routes. Change before deploying.
ADMIN_SECRET=changeme-local

# ─── SLA Timers (milliseconds) ──────────────────────────────────────────────
SLA_ACCEPT_MS=120000
SLA_CONTACT_MS=300000

# ─── Canonical Lead Platform ────────────────────────────────────────────────
# Canonical public domain. Set to https://www.askmagicmike.com in production.
# The Vercel dashboard must also set www.askmagicmike.com as the Production Domain.
# Vercel alias (ask-magic-mike.vercel.app) is never used as the public brand URL.
NEXT_PUBLIC_SITE_URL=https://www.askmagicmike.com
PUBLIC_SITE_URL=https://www.askmagicmike.com
ADMIN_BASE_URL=https://www.askmagicmike.com/admin

# Public lead capture
LEAD_RATE_LIMIT_PER_MINUTE=10

# Communications provider toggles. When ENABLE_* is false (default), the
# mock adapters log to console + analytics_events but never hit a carrier.
SMS_PROVIDER=mock              # mock | twilio
ENABLE_SMS=false
TWILIO_PHONE_NUMBER=

EMAIL_PROVIDER=mock            # mock | resend | sendgrid
EMAIL_API_KEY=
FROM_EMAIL=hello@ourtownproperties.com
ENABLE_EMAIL=false

# Lead notification outbox. Disabled is the safe default: assignment creates
# auditable notification records but does not contact agents or customers.
LEAD_NOTIFICATION_MODE=disabled # disabled | console | sandbox | production
NOTIFICATION_PROVIDER_MODE=disabled
AGENT_NOTIFICATIONS_ENABLED=false
AGENT_SMS_NOTIFICATIONS_ENABLED=false
CUSTOMER_EMAIL_ENABLED=false
CUSTOMER_SMS_ENABLED=false
AGENT_NOTIFICATION_FROM_EMAIL=
CONSOLE_NOTIFICATION_BEHAVIOR=success # success | retryable_failure | permanent_failure

# AI generation toggle. When false (default), MarketingAssetEngine runs
# the deterministic template path; AI-summary endpoints return placeholder.
ENABLE_AI_GENERATION=false

# FlexMLS / IDX
ENABLE_FLEXMLS_API=false
FLEXMLS_CLIENT_ID=
FLEXMLS_CLIENT_SECRET=
FLEXMLS_API_BASE_URL=

# Storage (lead/property photo uploads — not yet wired)
UPLOAD_STORAGE_BUCKET=

# Calendar (scheduling — not yet wired)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Analytics
GA_MEASUREMENT_ID=
META_PIXEL_ID=

# Auth (admin)
AUTH_SECRET=

# SLA cron (called by Vercel Cron / Inngest / external runner)
# When set, /api/admin/sla/sweep also accepts
# `Authorization: Bearer $CRON_SECRET` (in addition to x-admin-secret).
CRON_SECRET=

# Business hours used by SLA notifications (after-hours messaging).
BUSINESS_HOURS_TIMEZONE=America/New_York
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=20:00

# ─── Release-gate database identity ────────────────────────────────────────
# Used by /api/admin/health to decide whether the preview database is
# safe to mutate during QA runs. The health endpoint is the single
# source of truth — preview-qa.mjs refuses to mutate when this resolves
# unsafe, even with FORCE_DB_WRITE.
#
# DATABASE_ENV:                          preview | production | development
# SUPABASE_PROJECT_REF:                  the project ref of the Supabase
#                                        backing this deployment (e.g.
#                                        derived from NEXT_PUBLIC_SUPABASE_URL).
# PRODUCTION_SUPABASE_PROJECT_REF:       the production project ref. If
#                                        SUPABASE_PROJECT_REF matches this,
#                                        all mutation is blocked.
# PREVIEW_SUPABASE_PROJECT_REF:          the preview project ref. The
#                                        runner only allows mutation when
#                                        SUPABASE_PROJECT_REF matches this
#                                        (or DATABASE_ENV=preview and no
#                                        production ref is configured).
# ALLOW_PREVIEW_DB_MUTATION:             explicit opt-in toggle. Must be
#                                        "true" for safe_for_preview_mutation
#                                        to ever return true.
DATABASE_ENV=
SUPABASE_PROJECT_REF=
PRODUCTION_SUPABASE_PROJECT_REF=
PREVIEW_SUPABASE_PROJECT_REF=
ALLOW_PREVIEW_DB_MUTATION=false

# ─── Vercel deployment protection bypass (preview QA) ──────────────────────
# When Preview Deployment Protection is enabled, the preview QA runner
# needs to authenticate every request. Set ONE of these (precedence
# top-down). The runner sends the value as the
# `x-vercel-protection-bypass` header — never appended to URLs in
# artifacts. SET_VERCEL_BYPASS_COOKIE=true also sets the cookie header.
VERCEL_AUTOMATION_BYPASS_SECRET=
VERCEL_PROTECTION_BYPASS_TOKEN=
VERCEL_BYPASS_SECRET=
SET_VERCEL_BYPASS_COOKIE=false
