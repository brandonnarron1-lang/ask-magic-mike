# ─── Supabase ───────────────────────────────────────────────────────────────
# Required for database functionality. Get from supabase.com project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Providers ───────────────────────────────────────────────────────────
# Optional. Anthropic takes precedence over OpenAI. If neither is set,
# AI-augmented intent detection and valuation narratives are disabled.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── CRM Adapters ───────────────────────────────────────────────────────────
# Optional. If absent, the null adapter is used (no external CRM writes).
# All CRM calls are logged to crm_sync_log regardless.

# Follow Up Boss
FUB_API_KEY=
FUB_BASE_URL=https://api.followupboss.com/v1

# kvCORE
KVCORE_API_KEY=
KVCORE_BASE_URL=

# ─── Notifications ──────────────────────────────────────────────────────────
# Optional. Used for agent notification emails and SMS.
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# ─── AVM Providers ──────────────────────────────────────────────────────────
# Optional. If absent, mock provider is used (no real valuations).
ATTOM_API_KEY=
HOUSECANARY_API_KEY=
HOUSECANARY_API_SECRET=

# ─── App Configuration ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AGENT_NAME=Mike Eatmon
NEXT_PUBLIC_BROKERAGE_NAME=Our Town Properties
NEXT_PUBLIC_AGENT_PHONE=+12522454337
NEXT_PUBLIC_MARKET_AREA=Wilson, NC
NEXT_PUBLIC_AGENT_LICENSE=NC-YOUR-LICENSE-NUMBER

# ─── Admin ──────────────────────────────────────────────────────────────────
# Basic auth secret for /admin routes. Change before deploying.
ADMIN_SECRET=changeme-local

# ─── SLA Timers (milliseconds) ──────────────────────────────────────────────
SLA_ACCEPT_MS=120000
SLA_CONTACT_MS=300000

# ─── Canonical Lead Platform ────────────────────────────────────────────────
# Site (used by metadataBase + OG absolute URLs). Update on domain migration.
NEXT_PUBLIC_SITE_URL=https://ask-magic-mike.vercel.app
PUBLIC_SITE_URL=https://ask-magic-mike.vercel.app
ADMIN_BASE_URL=https://ask-magic-mike.vercel.app/admin

# Public lead capture
LEAD_RATE_LIMIT_PER_MINUTE=10

# Communications provider toggles. When ENABLE_* is false (default), the
# mock adapters log to console + analytics_events but never hit a carrier.
SMS_PROVIDER=mock              # mock | twilio
ENABLE_SMS=false
TWILIO_PHONE_NUMBER=

EMAIL_PROVIDER=mock            # mock | resend | sendgrid
EMAIL_API_KEY=
FROM_EMAIL=hello@ourtownproperties.com
ENABLE_EMAIL=false

# AI generation toggle. When false (default), MarketingAssetEngine runs
# the deterministic template path; AI-summary endpoints return placeholder.
ENABLE_AI_GENERATION=false

# FlexMLS / IDX
ENABLE_FLEXMLS_API=false
FLEXMLS_CLIENT_ID=
FLEXMLS_CLIENT_SECRET=
FLEXMLS_API_BASE_URL=

# Storage (lead/property photo uploads — not yet wired)
UPLOAD_STORAGE_BUCKET=

# Calendar (scheduling — not yet wired)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Analytics
GA_MEASUREMENT_ID=
META_PIXEL_ID=

# Auth (admin)
AUTH_SECRET=
